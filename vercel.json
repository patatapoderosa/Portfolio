{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/work",
      "destination": "/work.html"
    },
    {
      "source": "/work/:slug",
      "destination": "/work/:slug.html"
    }
  ]
}
